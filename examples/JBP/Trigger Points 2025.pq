let
    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Manufacturer = _t, #"Growth Scale 1" = _t, #" Trigger Point " = _t, #"Rebate 1" = _t, #"Profit 1" = _t, #"Growth Scale 2" = _t, #"Trigger Point 2" = _t, #"Rebate 2" = _t, #"Profit 2" = _t, #"Growth Scale 3" = _t, #"Trigger Point 3" = _t, #"Rebate 3" = _t, #"Profit 3" = _t]),
    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Manufacturer", type text}, {"Growth Scale 1", type number}, {" Trigger Point ", Currency.Type}, {"Rebate 1", type number}, {"Profit 1", Currency.Type}, {"Growth Scale 2", type number}, {"Trigger Point 2", Currency.Type}, {"Rebate 2", type number}, {"Profit 2", Currency.Type}, {"Growth Scale 3", type number}, {"Trigger Point 3", Currency.Type}, {"Rebate 3", type number}, {"Profit 3", Currency.Type}})
in
    #"Changed Type"