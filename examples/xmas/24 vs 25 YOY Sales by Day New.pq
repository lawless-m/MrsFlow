let
    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Day = _t, #"2024 Revenue" = _t, #"2025 Revenue" = _t, #"Deadline Day" = _t, Column1 = _t]),
    #"Changed Type" = Table.TransformColumnTypes(Source,{{"Day", Int64.Type}, {"2024 Revenue", Currency.Type}, {"2025 Revenue", Currency.Type}, {"Deadline Day", Currency.Type}})
in
    #"Changed Type"