let
    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [Customer = _t, #"2024 Sales" = _t, Column1 = _t]),
    #"Removed Columns1" = Table.RemoveColumns(Source,{"Column1"}),
    #"Changed Type" = Table.TransformColumnTypes(#"Removed Columns1",{{"Customer", type text}, {"2024 Sales", type number}})
in
