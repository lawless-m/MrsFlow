let
    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [IBM = _t, #"2024 Xmas Revenue" = _t]),
    #"Changed Type" = Table.TransformColumnTypes(Source,{{"IBM", type text}, {"2024 Xmas Revenue", Currency.Type}})
in
    #"Changed Type"